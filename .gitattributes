# .gitattributes -- Cadence Cycle Tracker
#
# Line-ending normalization, diff behavior, linguist overrides, binary handling.

# ── Global normalization ──────────────────────────────────────────────────────
* text=auto

# ── Swift source ──────────────────────────────────────────────────────────────
*.swift text diff

# ── Xcode project files ──────────────────────────────────────────────────────
# XcodeGen regenerates .pbxproj; union merge prevents spurious conflicts
# if the generated file is ever committed alongside other changes.
*.pbxproj merge=union linguist-generated
*.xcscheme text linguist-generated
*.xcworkspacedata text linguist-generated

# ── Config and data files ─────────────────────────────────────────────────────
*.plist text diff
*.json text diff
*.yml text diff
*.yaml text diff
*.entitlements text diff

# ── Documentation ─────────────────────────────────────────────────────────────
*.md text diff=markdown

# ── Shell scripts ─────────────────────────────────────────────────────────────
*.sh text eol=lf

# ── Image assets (binary -- never normalize) ──────────────────────────────────
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.pdf binary

# ── Provisioning and signing (binary) ─────────────────────────────────────────
*.mobileprovision binary
*.provisionprofile binary
*.p12 binary
*.p8 binary

# ── Linguist overrides ────────────────────────────────────────────────────────
# Keep GitHub language stats accurate (Swift, not XML or JSON)
docs/** linguist-documentation
*.css linguist-documentation
*.js linguist-documentation
*.html linguist-documentation
